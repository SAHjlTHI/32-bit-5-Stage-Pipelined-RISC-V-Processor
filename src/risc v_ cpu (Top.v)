module riscv_cpu (
    input clk,
    input rst,

    // Debug register outputs
    output [31:0] dbg_reg_x1,
    output [31:0] dbg_reg_x2,
    output [31:0] dbg_reg_x3,
    output [31:0] dbg_reg_x4
);

    //==================== FETCH STAGE ====================
    reg  [31:0] pc;
    wire [31:0] instr;
    wire stall;

    // IF/ID pipeline registers
    reg [31:0] if_id_instr;
    reg [31:0] if_id_pc;

    //==================== DECODE STAGE ====================
    wire [4:0] rs1 = if_id_instr[19:15];
    wire [4:0] rs2 = if_id_instr[24:20];
    wire [4:0] rd  = if_id_instr[11:7];

    // Immediate generation
    wire [31:0] imm_i = {{20{if_id_instr[31]}}, if_id_instr[31:20]};
    wire [31:0] imm_b = {{19{if_id_instr[31]}},
                         if_id_instr[31],
                         if_id_instr[7],
                         if_id_instr[30:25],
                         if_id_instr[11:8],
                         1'b0};

    wire alu_src, mem_to_reg, reg_write, mem_read, mem_write, branch;
    wire [1:0] alu_op;
    wire [3:0] alu_ctrl_w;

    wire [31:0] imm_final = branch ? imm_b : imm_i;
    wire [31:0] read_data1, read_data2;

    // ID/EX pipeline registers
    reg [31:0] id_ex_pc, id_ex_imm, id_ex_rs1_val, id_ex_rs2_val;
    reg [4:0]  id_ex_rs1, id_ex_rs2, id_ex_rd;
    reg [3:0]  id_ex_alu_ctrl;
    reg        id_ex_alu_src, id_ex_mem_to_reg, id_ex_reg_write;
    reg        id_ex_mem_read, id_ex_mem_write, id_ex_branch;

   //==================== EXECUTE STAGE ====================
    wire [1:0] forwardA, forwardB;
    wire [31:0] forwardA_data, forwardB_data;

    assign forwardA_data = (forwardA == 2'b10) ? ex_mem_alu_out :
                           (forwardA == 2'b01) ? write_back_data :
                           id_ex_rs1_val;

    assign forwardB_data = (forwardB == 2'b10) ? ex_mem_alu_out :
                           (forwardB == 2'b01) ? write_back_data :
                           id_ex_rs2_val;

    wire [31:0] alu_in2 = id_ex_alu_src ? id_ex_imm : forwardB_data;

    wire [31:0] alu_out =
        (id_ex_alu_ctrl == 4'b0010) ? (forwardA_data + alu_in2) :
        (id_ex_alu_ctrl == 4'b0110) ? (forwardA_data - alu_in2) :
        32'b0;

    wire zero = (alu_out == 0);

    wire take_branch = id_ex_branch && zero;
    wire [31:0] branch_target = id_ex_pc + id_ex_imm;

    // EX/MEM pipeline registers
    reg [31:0] ex_mem_alu_out, ex_mem_rs2_val;
    reg [4:0]  ex_mem_rd;
    reg        ex_mem_mem_to_reg, ex_mem_reg_write;
    reg        ex_mem_mem_read, ex_mem_mem_write;

    //==================== MEMORY STAGE ====================
    wire [31:0] mem_data_out;

    // MEM/WB pipeline registers
    reg [31:0] mem_wb_alu_out, mem_wb_mem_data;
    reg [4:0]  mem_wb_rd;
    reg        mem_wb_mem_to_reg, mem_wb_reg_write;

    //==================== WRITE BACK STAGE ====================
    wire [31:0] write_back_data =
        mem_wb_mem_to_reg ? mem_wb_mem_data : mem_wb_alu_out;

    //==================== MODULE INSTANTIATIONS ====================
    instr_mem imem (.addr(pc), .instr(instr));

    reg_file rf (
        .clk(clk), .rst(rst),
        .reg_write(mem_wb_reg_write),
        .rs1(rs1), .rs2(rs2), .rd(mem_wb_rd),
        .write_data(write_back_data),
        .read_data1(read_data1),
        .read_data2(read_data2),
        .dbg_x1(dbg_reg_x1),
        .dbg_x2(dbg_reg_x2),
        .dbg_x3(dbg_reg_x3),
        .dbg_x4(dbg_reg_x4)
    );

    control_unit cu (
        .opcode(if_id_instr[6:0]),
        .alu_src(alu_src),
        .mem_to_reg(mem_to_reg),
        .reg_write(reg_write),
        .mem_read(mem_read),
        .mem_write(mem_write),
        .branch(branch),
        .alu_op(alu_op)
    );

    alu_control aluctl (
        .alu_op(alu_op),
        .funct3(if_id_instr[14:12]),
        .funct7(if_id_instr[31:25]),
        .alu_ctrl(alu_ctrl_w)
    );

    data_mem dm (
        .clk(clk),
        .mem_read(ex_mem_mem_read),
        .mem_write(ex_mem_mem_write),
        .addr(ex_mem_alu_out),
        .write_data(ex_mem_rs2_val),
        .read_data(mem_data_out)
    );

    hazard_detection_unit hdu (
        .id_rs1(rs1),
        .id_rs2(rs2),
        .ex_rd(id_ex_rd),
        .ex_mem_read(id_ex_mem_read),
        .stall(stall)
    );

    forwarding_unit fwdu (
        .ex_rs1(id_ex_rs1),
        .ex_rs2(id_ex_rs2),
        .mem_rd(ex_mem_rd),
        .wb_rd(mem_wb_rd),
        .mem_reg_write(ex_mem_reg_write),
        .wb_reg_write(mem_wb_reg_write),
        .forwardA(forwardA),
        .forwardB(forwardB)
    );

    //==================== PIPELINE REGISTERS ====================
    always @(posedge clk or posedge rst) begin
        if (rst) begin
            pc <= 0;
            if_id_instr <= 0;
            if_id_pc <= 0;

            id_ex_pc <= 0; id_ex_imm <= 0;
            id_ex_rs1_val <= 0; id_ex_rs2_val <= 0;
            id_ex_rs1 <= 0; id_ex_rs2 <= 0; id_ex_rd <= 0;
            id_ex_alu_ctrl <= 0;
            id_ex_alu_src <= 0; id_ex_mem_to_reg <= 0;
            id_ex_reg_write <= 0; id_ex_mem_read <= 0;
            id_ex_mem_write <= 0; id_ex_branch <= 0;

            ex_mem_alu_out <= 0; ex_mem_rs2_val <= 0;
            ex_mem_rd <= 0;
            ex_mem_mem_to_reg <= 0; ex_mem_reg_write <= 0;
            ex_mem_mem_read <= 0; ex_mem_mem_write <= 0;

            mem_wb_alu_out <= 0; mem_wb_mem_data <= 0;
            mem_wb_rd <= 0;
            mem_wb_mem_to_reg <= 0; mem_wb_reg_write <= 0;
        end else begin
            if (!stall) begin
                pc <= take_branch ? branch_target : pc + 4;
            end

            if (take_branch) begin
                if_id_instr <= 0;
                if_id_pc <= 0;
            end else if (!stall) begin
                if_id_instr <= instr;
                if_id_pc <= pc;
            end

            id_ex_pc <= stall ? 0 : if_id_pc;
            id_ex_imm <= stall ? 0 : imm_final;
            id_ex_rs1 <= stall ? 0 : rs1;
            id_ex_rs2 <= stall ? 0 : rs2;
            id_ex_rd <= stall ? 0 : rd;
            id_ex_rs1_val <= stall ? 0 : read_data1;
            id_ex_rs2_val <= stall ? 0 : read_data2;
            id_ex_alu_ctrl <= stall ? 0 : alu_ctrl_w;
            id_ex_alu_src <= stall ? 0 : alu_src;
            id_ex_mem_to_reg <= stall ? 0 : mem_to_reg;
            id_ex_reg_write <= stall ? 0 : reg_write;
            id_ex_mem_read <= stall ? 0 : mem_read;
            id_ex_mem_write <= stall ? 0 : mem_write;
            id_ex_branch <= stall ? 0 : branch;

            ex_mem_alu_out <= alu_out;
            ex_mem_rs2_val <= forwardB_data;
            ex_mem_rd <= id_ex_rd;
            ex_mem_mem_to_reg <= id_ex_mem_to_reg;
            ex_mem_reg_write <= id_ex_reg_write;
            ex_mem_mem_read <= id_ex_mem_read;
            ex_mem_mem_write <= id_ex_mem_write;

            mem_wb_alu_out <= ex_mem_alu_out;
            mem_wb_mem_data <= mem_data_out;
            mem_wb_rd <= ex_mem_rd;
            mem_wb_mem_to_reg <= ex_mem_mem_to_reg;
            mem_wb_reg_write <= ex_mem_reg_write;
        end
    end
endmodule

/////////////////////////////////////////////////////////////////////////////////
module instr_mem (
    input [31:0] addr,
    output [31:0] instr
);
    reg [31:0] memory [0:255];

    initial begin
        // Expanded program with R-type, I-type, branches and jumps
        memory[0] = 32'h00500093; // addi x1, x0, 5
        memory[1] = 32'h00a00113; // addi x2, x0, 10
        memory[2] = 32'h002081b3; // add x3, x1, x2
        memory[3] = 32'h40328233; // sub x4, x5, x3 (x5 is 0)
        memory[4] = 32'h0011a023; // sw x1, 0(x3)
        memory[5] = 32'h0001a183; // lw x3, 0(x3)
        memory[6] = 32'h0041c463; // beq x3, x4, +8
        memory[7] = 32'h00000013; // nop (executed if branch not taken)
        memory[8] = 32'h00000013; // nop
        memory[9] = 32'h00000013; // nop
        memory[10] = 32'h00000013; // nop
        memory[11] = 32'h00000013; // nop
        memory[12] = 32'h00000013; // nop (target of branch)
        memory[13] = 32'h00000013; // nop
        memory[14] = 32'h00000013; // nop
        memory[15] = 32'h00000013; // nop
        memory[16] = 32'h00000013; // nop
        memory[17] = 32'h00000013; // nop
        memory[18] = 32'h00000013; // nop
        memory[19] = 32'h00000013; // nop
        memory[20] = 32'h00000013; // nop
    end

    assign instr = memory[addr[9:2]];
endmodule

//////////////////////////////////////////////////////////////////////////////////
module reg_file (
    input clk,
    input rst,
    input reg_write,
    input [4:0] rs1,
    input [4:0] rs2,
    input [4:0] rd,
    input [31:0] write_data,
    output [31:0] read_data1,
    output [31:0] read_data2,

    // Debug outputs
    output [31:0] dbg_x1,
    output [31:0] dbg_x2,
    output [31:0] dbg_x3,
    output [31:0] dbg_x4
);

    reg [31:0] regs [0:31];

    // Synchronous Write
     integer i;
    always @(posedge clk or posedge rst) begin
        if (rst) begin
           
            for (i = 0; i < 32; i = i + 1)
                regs[i] <= 0;
        end else if (reg_write && rd != 0) begin
            regs[rd] <= write_data;
        end
    end

    // Read Combinational
    assign read_data1 = regs[rs1];
    assign read_data2 = regs[rs2];

    // Debug Ports (x1 to x4)
    assign dbg_x1 = regs[1];
    assign dbg_x2 = regs[2];
    assign dbg_x3 = regs[3];
    assign dbg_x4 = regs[4];

endmodule


module control_unit (
    input [6:0] opcode,
    output reg alu_src, mem_to_reg, reg_write, mem_read, mem_write, branch,
    output reg [1:0] alu_op
);
    always @(*) begin
        alu_src     = 0;
        mem_to_reg  = 0;
        reg_write   = 0;
        mem_read    = 0;
        mem_write   = 0;
        branch      = 0;
        alu_op      = 2'b00;

        case (opcode)
            7'b0010011: begin // addi
                alu_src = 1;
                reg_write = 1;
                alu_op = 2'b00;
            end
            7'b0000011: begin // lw
                alu_src = 1;
                reg_write = 1;
                mem_to_reg = 1;
                mem_read = 1;
                alu_op = 2'b00;
            end
            7'b0100011: begin // sw
                alu_src = 1;
                mem_write = 1;
                alu_op = 2'b00;
            end
            7'b1100011: begin // beq
                branch = 1;
                alu_op = 2'b01;
            end
        endcase
    end
endmodule

module alu_8bit (
    input  [7:0] a,
    input  [7:0] b,
    input  [3:0] alu_ctrl,
    output reg [7:0] result
);
    always @(*) begin
        case (alu_ctrl)
            4'b0000: result = a & b;                 // AND
            4'b0001: result = a | b;                 // OR
            4'b0010: result = a + b;                 // ADD
            4'b0011: result = a ^ b;                 // XOR
            4'b0100: result = (a < b) ? 8'b1 : 8'b0; // SLT
            4'b0101: result = a - b;                 // SUB
            default: result = 8'b0;
        endcase
    end
endmodule

module alu_control (
    input [1:0] alu_op,
    input [2:0] funct3,
    input [6:0] funct7,
    output reg [3:0] alu_ctrl
);
    always @(*) begin
        case (alu_op)
            2'b00: alu_ctrl = 4'b0010; // add for lw/sw/addi
            2'b01: alu_ctrl = 4'b0110; // sub for beq
            default: alu_ctrl = 4'b0000;
        endcase
    end
endmodule



module data_mem (
    input clk,
    input mem_read, mem_write,
    input [31:0] addr,
    input [31:0] write_data,
    output reg [31:0] read_data
);
    reg [31:0] memory [0:255];

    always @(posedge clk) begin
        if (mem_write)
            memory[addr[9:2]] <= write_data;
    end

    always @(*) begin
        if (mem_read)
            read_data = memory[addr[9:2]];
        else
            read_data = 32'b0;
    end
endmodule




module hazard_detection_unit(
    input [4:0] id_rs1,
    input [4:0] id_rs2,
    input [4:0] ex_rd,
    input       ex_mem_read,
    output reg  stall
);
    always @(*) begin
        if (ex_mem_read && (ex_rd != 0) &&
   ((ex_rd == id_rs1) || (ex_rd == id_rs2)))

            stall = 1;
        else
            stall = 0;
    end
endmodule


module forwarding_unit(
    input  [4:0] ex_rs1, ex_rs2,
    input  [4:0] mem_rd, wb_rd,
    input        mem_reg_write, wb_reg_write,
    output reg [1:0] forwardA, forwardB
);
    always @(*) begin
        forwardA = 2'b00;
        forwardB = 2'b00;

        if (mem_reg_write && (mem_rd != 0) && (mem_rd == ex_rs1)) forwardA = 2'b10;
        if (mem_reg_write && (mem_rd != 0) && (mem_rd == ex_rs2)) forwardB = 2'b10;

        if (wb_reg_write && (wb_rd != 0) && (wb_rd == ex_rs1)) forwardA = 2'b01;
        if (wb_reg_write && (wb_rd != 0) && (wb_rd == ex_rs2)) forwardB = 2'b01;
    end
endmodule
